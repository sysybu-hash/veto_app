# Dependencies
node_modules/

# Backend secrets (never commit)
backend/.env
backend/.env.*
!backend/.env.example
.env
.env.*
!.env.example
.env.local
*.pem

# Logs & OS
npm-debug.log*
.DS_Store
Thumbs.db

# Flutter
frontend/.dart_tool/
# Ignore build output except web bundle (Vercel serves frontend/build/web).
# Cannot use "frontend/build" + "!frontend/build/web" — Git ignores parent first.
frontend/build/*
!frontend/build/web/
!frontend/build/web/**
frontend/.flutter-plugins-dependencies

# IDE
.idea/
*.iml
.claude/

# Local Flutter SDK checkout (do not commit)
flutter/

.vercel
.env*.local
