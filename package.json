{
  "name": "veto-app",
  "private": true,
  "description": "VETO Legal Emergency — root helpers (backend + tunnel)",
  "workspaces": [],
  "scripts": {
    "check:git-secrets": "node scripts/verify-no-secrets-in-git.js",
    "render-build": "npm ci --prefix backend",
    "render-start": "npm start --prefix backend",
    "install:backend": "npm install --prefix backend",
    "dev": "npm run dev --prefix backend",
    "dev:clean": "npm run dev:clean --prefix backend",
    "free-5001": "npm run free-5001 --prefix backend",
    "start": "npm start --prefix backend",
    "tunnel": "npm run tunnel --prefix backend",
    "tunnel:any": "npm run tunnel:any --prefix backend",
    "tunnel:help": "npm run tunnel:help --prefix backend",
    "dev:urls": "npm run dev:urls --prefix backend",
    "build:web": "cd frontend && flutter build web --release --no-wasm-dry-run --no-tree-shake-icons --pwa-strategy=none --dart-define=VETO_API_BASE=https://veto-legal.onrender.com",
    "ship:web": "npm run build:web && npm run vercel:check",
    "vercel:check": "node scripts/vercel-assert-prebuilt.cjs",
    "e2e:flutter": "cd frontend && flutter test test/e2e_all_routes_test.dart test/e2e_landing_login_test.dart && flutter test test/e2e_network_routes_test.dart"
  }
}
