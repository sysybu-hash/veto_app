{
  "name": "veto-backend",
  "version": "1.0.0",
  "description": "VETO Legal Emergency App – Node.js Backend",
  "main": "server.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "free-5001": "kill-port 5001",
    "dev:clean": "kill-port 5001 && nodemon server.js",
    "init-admins": "node scripts/init_admins.js",
    "tunnel": "node scripts/tunnel-run.js",
    "tunnel:cli": "lt --port 5001 --subdomain sweet-turkey-60",
    "tunnel:any": "lt --port 5001",
    "tunnel:help": "node scripts/tunnel-help.js",
    "dev:urls": "node scripts/print-dev-urls.js",
    "lint": "eslint src scripts server.js",
    "test": "node --test ./test/crypto_otp.test.js ./test/ai_routes_mount.test.js"
  },
  "dependencies": {
    "@google/genai": "^1.48.0",
    "@google/generative-ai": "^0.24.1",
    "@sentry/node": "^10.47.0",
    "axios": "^1.14.0",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.6",
    "debug": "^4.4.3",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.5.1",
    "follow-redirects": "^1.16.0",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.4.1",
    "multer": "^2.1.1",
    "multer-storage-cloudinary": "^4.0.0",
    "socket.io": "^4.7.5",
    "web-push": "^3.6.7",
    "yargs": "^18.0.0",
    "yargs-parser": "^22.0.0"
  },
  "overrides": {
    "multer-storage-cloudinary": {
      "cloudinary": "$cloudinary"
    },
    "localtunnel": {
      "axios": "1.15.2",
      "follow-redirects": "1.16.0",
      "debug": "4.4.3"
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "kill-port": "^2.0.1",
    "localtunnel": "^2.0.2",
    "nodemon": "^3.1.4"
  }
}
