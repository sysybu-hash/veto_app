# ============================================================
#  .env.example — VETO Backend
#  העתק ל-.env ומלא ערכים. קובץ זה בטוח ב-git (ללא סודות).
#  מדריך מפורט: ENV_GUIDE.md
# ============================================================

# ── Server ────────────────────────────────────────────────
PORT=5001
NODE_ENV=development

# ── Database ──────────────────────────────────────────────
# MongoDB Atlas: Cluster → Connect → Drivers → copy string
# https://www.mongodb.com/docs/atlas/driver-connection/
# החלף <username>, <password>, <dbname> · סיסמא: URL-encode אם צריך
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/<dbname>?retryWrites=true&w=majority

# ── Auth ──────────────────────────────────────────────────
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_long_random_secret_min_64_chars
JWT_EXPIRES_IN=30d

# ── Google OAuth ──────────────────────────────────────────
# https://console.cloud.google.com/apis/credentials — OAuth 2.0 (Web)
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret

# ── Google Calendar API (OAuth נפרד מהתחברות — סנכרון אירועים) ─
# לקוח OAuth 2.0 נפרד ב-GCP עם scope calendar.events · Redirect: .../api/integrations/gcal/callback
# GOOGLE_CALENDAR_CLIENT_ID=
# GOOGLE_CALENDAR_CLIENT_SECRET=
# GCAL_OAUTH_REDIRECT_URI=http://localhost:5001/api/integrations/gcal/callback
# אופציונלי: הפניה אחרי הצלחה (דפדפן)
# GCAL_OAUTH_SUCCESS_REDIRECT=https://your-app.vercel.app/legal_calendar
# מומלץ בפרוד: מפתח הצפנה ייעודי (32+ בתים); אחרת נגזר מ-JWT_SECRET
# GCAL_TOKEN_ENC_KEY=

# ── AI — Google Gemini (צ'אט משפטי + תמלול + ניתוח כספת) ─
# https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key
# GEMINI_MODEL=gemini-2.5-flash
# גודל מקס' לבקשת ניתוח (ברירת מחדל בקוד ~20MB) — אופציונלי
# VAULT_ANALYSIS_MAX_BYTES=20971520

# ── Agora RTC (שיחות וידאו/אודיו — חובה בפרוד אם ב-Agora הופעל App Certificate) ─
# App ID: זהה לקובץ Flutter: frontend/lib/services/agora_service.dart (kAgoraAppIdPlaceholder)
# Certificate: Agora Console → Your project → All features → App ID → show certificate
# בלי certificate: השרת שולח agoraToken ריק; join רק אם הפרויקט ב-Agora מאפשר "Secured" כבוי / join ללא token
# AGORA_APP_ID=b40f2355783a4ccca027a91d0d7100ca
# AGORA_APP_CERTIFICATE=your_app_certificate

# ── Agora Cloud Recording (דפדפן: מיקס מלא → S3 → Cloudinary) ─
# מסוף Agora → Cloud Recording → RESTful customer ID/secret
# https://docs.agora.io/en/cloud-recording/get-started/getstarted
# AGORA_RESTFUL_CUSTOMER_ID=
# AGORA_RESTFUL_CUSTOMER_SECRET=
# AGORA_RESTFUL_DOMAIN=https://api.sd-rtn.com
# מספר אזור S3 לפי Agora vendor=1 — חייב להתאים לאזור ה-bucket (לא לאותו שם כמו AWS!)
# דוגמה: us-east-1 (N. Virginia) → 0 · us-east-2 → 1 · eu-west-1 → 4
# https://docs.agora.io/en/cloud-recording/reference/region-vendor
# AGORA_CR_S3_REGION_NUM=0
# AGORA_CR_S3_BUCKET=your-bucket
# AGORA_CR_S3_ACCESS_KEY=
# AGORA_CR_S3_SECRET_KEY=
# אזור AWS ל-SDK (למשל us-east-1) — חייב להתאים ל-bucket
# AGORA_CR_AWS_REGION=us-east-1

# ── Cloudinary (הקלטות, ראיות, כספה) ─────────────────────
# https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ── Web Push (VAPID) — בדפדפן, לא Firebase ────────────────
# npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:admin@veto-legal.com

# ── Public API base (יומן — iCal / webcal URL מלא) ───────
# origin בלבד, בלי /api (לדוגמה https://your-api.onrender.com)
# PUBLIC_API_BASE=https://your-api.onrender.com
# (שם חלופי) VETO_PUBLIC_BASE=...

# ── SMTP (אופציונלי — אימייל אירועי יומן / ICS) ──────────
# Resend: https://resend.com/docs/send-with-smtp
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@yourdomain.com

# ── Cron (תזכורות — רק אם מריצים node scripts/cron-calendar-reminders.js) ─
# MONGO_URI חייב מוגדר באותו סביבה
# חלון סריקה בדקות (ר' scripts/cron-calendar-reminders.js)
# CALENDAR_REMINDER_WINDOW_MIN=8

# ── Cron (סנכרון Google Calendar — רק אם OAuth מוגדר) ─
# npm run cron:gcal-sync
# GCAL_SYNC_LOOKAHEAD_DAYS=120

# ── NotebookLM Enterprise (אופציונלי, GCP) — לא Firebase ─
# https://cloud.google.com/gemini/enterprise/notebooklm-enterprise/docs
# GCP_PROJECT_ID=your-gcp-project-id
# JSON אחת בשורה — תוכן קובץ service account
# GOOGLE_NOTEBOOKLM_SA_JSON={"type":"service_account",...}
# (שם חלופי) GOOGLE_APPLICATION_CREDENTIALS_JSON=...
# NOTEBOOKLM_ENT_URL=https://notebooklm.cloud.google.com

# ── Monitoring (Sentry) — אופציונלי ──────────────────────
# https://sentry.io — Node.js DSN (עם @ בכתובת)
SENTRY_DSN=

# ── PayPal (תשלומים / מנוי) — אופציונלי ─────────────────
# https://developer.paypal.com/
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# sandbox | live
PAYPAL_ENV=sandbox

# ── Frontend (אחרי תשלום PayPal חוזרים לכאן) — אופציונלי
FRONTEND_URL=https://your-app.vercel.app

# ── WebRTC / TURN (אופציונלי) ─────────────────────────────
# WEBRTC_ICE_SERVERS_JSON=[...]
# TURN_URL=turn:turn.example.com:3478?transport=tcp
# TURN_USERNAME=
# TURN_CREDENTIAL=

# ── OTP בפיתוח (אין SMS עדיין) — אסור בפרוד בלי Twilio! ─
# RETURN_OTP_IN_JSON=1

# ── Tunnel (פיתוח) ───────────────────────────────────────
# TUNNEL_SUBDOMAIN=sweet-turkey-60

# ============ בלי Firebase — אין למלא: =================
# FCM / firebase-admin: לא
# # FIREBASE_SERVICE_ACCOUNT=
