# העתק ל-.env ומלא ערכים
PORT=5001
# Optional: npm run tunnel requests this subdomain first (may fall back to random)
# TUNNEL_SUBDOMAIN=sweet-turkey-60
NODE_ENV=development

MONGO_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/veto?retryWrites=true&w=majority

JWT_SECRET=your_long_random_secret
JWT_EXPIRES_IN=30d

# CORS — * לפיתוח; בפרודקשן רשום דומיינים מופרדים בפסיקים
CLIENT_ORIGIN=*

# Render / cloud: הגדר את אותם משתנים ב-Dashboard (MONGO_URI, JWT_SECRET, NODE_ENV=production).
# PORT מוגדר אוטומטית — לא חובה ב-.env בפרודקשן.
