# ============================================================
#  .env.example — VETO Backend
#  העתק ל-.env ומלא ערכים. קובץ זה בטוח ב-git (ללא סודות).
# ============================================================

# ── Server ────────────────────────────────────────────────
PORT=5001
NODE_ENV=development

# ── Database ──────────────────────────────────────────────
# MongoDB Atlas: Cluster → Connect → Drivers → copy string
# החלף <username>, <password>, <dbname>
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/<dbname>?retryWrites=true&w=majority

# ── Auth ──────────────────────────────────────────────────
# צור סוד חזק: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_long_random_secret_min_64_chars
JWT_EXPIRES_IN=30d

# ── Google OAuth ──────────────────────────────────────────
# Google Console → APIs & Services → Credentials → Web client
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret

# ── AI — Google Gemini (תמלול שיחות) ─────────────────────
# Google AI Studio: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key

# ── Cloudinary (הקלטות וידאו + ראיות) ────────────────────
# Cloudinary Dashboard → Account → API Keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ── Web Push (VAPID) ──────────────────────────────────────
# צור זוג מפתחות: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:admin@veto-legal.com

# ── Monitoring (Sentry) — אופציונלי ──────────────────────
# https://sentry.io → Create Project → Node.js → DSN
SENTRY_DSN=

# ── OTP בפיתוח (אין SMS עדיין) ────────────────────────────
# הפעל כדי לקבל OTP בתגובת ה-API (להסיר בפרודקשן!)
# RETURN_OTP_IN_JSON=1

# ── Tunnel (פיתוח מקומי) ──────────────────────────────────
# אופציונלי: npm run tunnel יבקש subdomain זה ראשון
# TUNNEL_SUBDOMAIN=sweet-turkey-60
